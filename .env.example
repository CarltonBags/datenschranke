# Copy to .env (deploy.sh generates missing secrets on first run).
# NEVER commit a real .env.

# --- Secrets (generated by deploy.sh via `openssl rand` if absent) ----------
POSTGRES_PASSWORD=
GATEWAY_DB_PASSWORD=
# 32 bytes, base64. Envelope-encryption master key (KMS in real prod).
MASTER_ENCRYPTION_KEY=
# Product A session secret (OIDC).
SESSION_SECRET=

# --- Provider routing -------------------------------------------------------
# `mock` uses the local provider mock (dev). `openai` / `azure-openai` hit real.
DEFAULT_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# --- Ports (host-side) ------------------------------------------------------
GATEWAY_PORT=8080
WEB_PORT=3000
REDACTOR_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# --- Misc -------------------------------------------------------------------
MOCK_LATENCY_MS=40
# Public domain for the prod Caddy TLS config.
PUBLIC_DOMAIN=localhost
# Set by `deploy.sh --seed`; used by the web demo login.
DEMO_TENANT_ID=
